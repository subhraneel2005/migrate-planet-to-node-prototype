datasource db {
  provider = "mysql"
}

model LikesToProjects {
  RowID     BigInt   @id @db.BigInt
  ProjectID BigInt   @db.BigInt
  UserID    BigInt   @db.BigInt
  Project   Projects @relation(fields: [ProjectID], references: [ProjectID], onDelete: Cascade)
  User      User     @relation(fields: [UserID], references: [UserID], onDelete: Cascade)

  @@index([ProjectID])
  @@index([UserID])
}

model NewUserInvitations {
  Token            String   @id @db.VarChar(50)
  TokenCreatedDate DateTime @default(now()) @db.DateTime(0)
}

model Projects {
  ProjectID             BigInt            @id @db.BigInt
  UserID                BigInt            @db.BigInt
  ProjectName           String            @db.VarChar(50)
  ProjectDescription    String            @db.VarChar(1000)
  ProjectSearchKeywords String            @db.Text
  ProjectData           String            @db.LongText
  ProjectImage          String?           @db.LongText
  ProjectIsMusicBlocks  Boolean           @db.TinyInt()
  ProjectCreatorName    String            @default("anonymous") @db.VarChar(50)
  ProjectCreatedDate    DateTime          @default(now()) @db.DateTime(0)
  ProjectDownloads      Int               @default(0) @db.Int
  ProjectLikes          Int               @default(0) @db.Int
  ProjectLastUpdated    DateTime          @default(now()) @db.Timestamp(0)
  User                  User              @relation(fields: [UserID], references: [UserID], onDelete: Cascade)
  LikesToProjects       LikesToProjects[]
  Reports               Reports[]
  TagsToProjects        TagsToProjects[]

  Repository Repository?

  ForksFrom Fork[] @relation("ForkSource")
  ForksTo   Fork[] @relation("ForkTarget")

  @@index([UserID])
}

model Reports {
  ReportID    Int      @id @db.Int
  ProjectID   BigInt   @db.BigInt
  UserID      BigInt   @db.BigInt
  Description String   @db.VarChar(1000)
  Project     Projects @relation(fields: [ProjectID], references: [ProjectID], onDelete: Cascade)
  User        User     @relation(fields: [UserID], references: [UserID], onDelete: Cascade)

  @@index([ProjectID])
  @@index([UserID])
}

model Tags {
  TagID            Int              @id @db.Int
  TagName          String           @db.VarChar(50)
  IsTagUserAddable Boolean          @db.TinyInt()
  IsDisplayTag     Boolean          @db.TinyInt()
  TagsToProjects   TagsToProjects[]
}

model TagsToProjects {
  RowID     Int      @id @db.Int
  TagID     Int      @db.Int
  ProjectID BigInt   @db.BigInt
  Project   Projects @relation(fields: [ProjectID], references: [ProjectID], onDelete: Cascade)
  Tag       Tags     @relation(fields: [TagID], references: [TagID], onDelete: Cascade)

  @@index([TagID])
  @@index([ProjectID])
}

model User {
  UserID          BigInt            @id @db.BigInt
  Username        String            @db.VarChar(50)
  Email           String            @db.VarChar(50)
  Phash           String            @db.VarChar(255)
  Projects        Projects[]
  LikesToProjects LikesToProjects[]
  Reports         Reports[]
}

model Repository {
  RepoID        Int      @id @default(autoincrement())
  ProjectID     BigInt   @unique
  Reponame      String
  GithubRepoID  Int
  DefaultBranch String   @default("main")
  RepoURL       String
  CreatedAt     DateTime @default(now())

  Project Projects @relation(fields: [ProjectID], references: [ProjectID], onDelete: Cascade)

  Commits Commit[]

  PRsReceived PullRequest[] @relation("PRTarget")
  PRsOpened   PullRequest[] @relation("PRSource")
}

model Fork {
  ForkID Int @id @default(autoincrement())

  SourceProjectID BigInt
  ForkedProjectID BigInt

  ForkedByUserID BigInt

  SourceProject Projects @relation("ForkSource", fields: [SourceProjectID], references: [ProjectID])
  ForkedProject Projects @relation("ForkTarget", fields: [ForkedProjectID], references: [ProjectID])

  ForkedAt DateTime @default(now())
}

model Commit {
  CommitID      Int      @id @default(autoincrement())
  RepoID        Int
  CommitSHA     String
  CommitMessage String
  CommitedBy    BigInt
  CommitedAt    DateTime @default(now())

  Repository Repository @relation(fields: [RepoID], references: [RepoID], onDelete: Cascade)
}

model PullRequest {
  PRID            Int       @id @default(autoincrement())
  SourceRepoID    Int
  TargetRepoID    Int
  PRNumber        Int
  Title           String
  Status          PR_STATUS @default(OPEN)
  CreatedByUserID BigInt

  SourceRepo Repository @relation("PRSource", fields: [SourceRepoID], references: [RepoID])
  TargetRepo Repository @relation("PRTarget", fields: [TargetRepoID], references: [RepoID])
  CreatedAt  DateTime   @default(now())
}

enum PR_STATUS {
  OPEN
  CLOSED
  MERGED
}
